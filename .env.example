# =============================================================================
# Client Onboarding Playbook — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in values as needed.
#
#   cp .env.example .env.local
#
# The app runs fully client-side against local content by default, so NONE of
# these are required to develop or deploy. They exist for optional integrations
# and to document the intended configuration surface.
# -----------------------------------------------------------------------------

# Public site URL (used for metadata / canonical links). Optional.
# Example: https://onboarding.buildvision.io
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Human-readable app name shown in the UI header. Optional (defaults in code).
NEXT_PUBLIC_APP_NAME="Client Onboarding Playbook"

# Optional analytics key (e.g. Vercel Analytics, PostHog). Leave blank to disable.
# NEXT_PUBLIC_ANALYTICS_KEY=""

# -----------------------------------------------------------------------------
# SUPABASE BACKEND (optional) — enables shared, cross-device data + team login.
# When BOTH are set, customers/intake/portal move to Supabase and the internal
# dashboard requires an email/password sign-in. When absent, the app runs as the
# single-browser localStorage tool. Both values are PUBLIC (safe to expose); the
# anon key is protected by row-level security. NEVER put the service_role key here.
# In production, set these as GitHub Actions repo secrets of the same names.
# See docs/BACKEND_SETUP.md.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
