# =============================================================================
# Client Onboarding Playbook — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in values as needed.
#
#   cp .env.example .env.local
#
# The app runs fully client-side against local content by default, so NONE of
# these are required to develop or deploy. They exist for optional integrations
# and to document the intended configuration surface.
# -----------------------------------------------------------------------------

# Public site URL (used for metadata / canonical links). Optional.
# Example: https://onboarding.buildvision.io
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Human-readable app name shown in the UI header. Optional (defaults in code).
NEXT_PUBLIC_APP_NAME="Client Onboarding Playbook"

# Optional analytics key (e.g. Vercel Analytics, PostHog). Leave blank to disable.
# NEXT_PUBLIC_ANALYTICS_KEY=""

# -----------------------------------------------------------------------------
# FUTURE / OPTIONAL — not used by the current build, documented for roadmap:
# If you later add a shared backend (multi-user progress, admin editing, auth),
# wire these up. See README "Roadmap & extension points".
# -----------------------------------------------------------------------------
# DATABASE_URL=""
# AUTH_SECRET=""
